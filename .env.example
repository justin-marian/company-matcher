APP_ENV=development
API_PREFIX=/api
ALLOWED_ORIGINS=["http://localhost:5173"]

ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-opus-4-5
EMBED_MODEL=all-MiniLM-L6-v2

DATA_PATH=backend/data/companies.jsonl
PROMPTS_PATH=prompts
DB_PATH=backend/data/companies.sqlite
TABLE_NAME=companies

TOP_K=25
BATCH_SIZE=5
MAX_CONCURRENT=5
QUALIFY_THRESHOLD=5

USE_SQL=true
REBUILD_DB=false
